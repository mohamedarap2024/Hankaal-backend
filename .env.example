PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret-in-production
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Shared secret — must match VITE_API_KEY on frontend (blocks direct API access)
API_SECRET=change-this-to-a-long-random-api-secret

# Comma-separated allowed frontend URLs (Vercel + custom domain + local)
CORS_ORIGIN=https://www.hankaal.so,https://hankaal.so,http://localhost:8081
FRONTEND_URL=https://www.hankaal.so

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
